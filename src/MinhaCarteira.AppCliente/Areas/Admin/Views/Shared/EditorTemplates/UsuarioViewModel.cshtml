@model MinhaCarteira.AppCliente.ViewModel.UsuarioViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="OrganizacaoId" class="form-control" />

<fieldset>
    <legend class="col-form-label">Dados pessoais</legend>

    <div class="row">
        <div class="form-group col-sm-6">
            <label asp-for="Id" class="control-label"></label>
            <input disabled asp-for="Id" class="form-control" />
            <span asp-validation-for="Id" class="text-danger"></span>
        </div>

        <div class="form-group col-sm-3">
            <label asp-for="DataCadastro" class="control-label"></label>
            <input disabled asp-for="DataCadastro" class="form-control" />
            <span asp-validation-for="DataCadastro" class="text-danger"></span>
        </div>

        <div class="form-group col-sm-3">
            <label asp-for="DataAtualizacao" class="control-label"></label>
            <input disabled asp-for="DataAtualizacao" class="form-control" />
            <span asp-validation-for="DataAtualizacao" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="form-group col-sm-6">
            <label asp-for="Nome" class="control-label"></label>
            <input asp-for="Nome" class="form-control" autofocus />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="form-group col-sm-6">
            <label asp-for="Sobrenome" class="control-label"></label>
            <input asp-for="Sobrenome" class="form-control" />
            <span asp-validation-for="Sobrenome" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="form-group col-sm-6">
            <label asp-for="Username" class="control-label"></label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="form-group col-sm-6">
            <label asp-for="Email" class="control-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <input type="hidden" asp-for="PasswordHash" class="form-control" />
    </div>
</fieldset>

<hr />
<fieldset>
    <legend class="col-form-label">Papéis de usuário</legend>

    @if (Model is { Papeis: not null } && Model.Papeis.Any())
    {
        @foreach (var item in Model.Papeis)
        {
            <h4 class="d-inline-block">
                <span class="badge bg-success p-2">@item.Papel.Nome</span>
            </h4>
        }
    }
</fieldset>

<div class="form-group">
    <hr />
    <input asp-accessando-como type="submit" value="Salvar" class="btn @(ViewBag.ClasseBotao)primary" />

    <a class="btn @(ViewBag.ClasseBotao)secondary" asp-action="Index">Cancelar</a>
</div>
