@model MinhaCarteira.AppCliente.ViewModel.CategoriaViewModel

@{
    ViewData["Title"] = "CategoriaViewModel";
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input hidden asp-for="Icone.Conteudo" />
<input hidden asp-for="Icone.Nome" />

<div class="row">
    <div class="col-sm-9 mb-3">
        <div class="row">
            <div class="col-sm-6 mb-3">
                <label asp-for="Id" class="form-label"></label>
                <input asp-for="Id" class="form-control" disabled />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>

            <div class="col-sm-6 mb-3">
                <label asp-for="IdAuxiliar" class="form-label"></label>
                <input asp-for="IdAuxiliar" class="form-control" />
                <span asp-validation-for="IdAuxiliar" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-6 mb-3">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" autofocus />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="mb-3 col-sm-6">
                <label asp-for="CategoriaPaiId" class="form-label"></label>
                <input type="hidden" asp-for="CategoriaPaiId" class="form-control" />
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fa fa-search"></i>
                    </span>
                    <input type="search" id="txtCategoriaPai" asp-for="NomeCategoriaPai" class="form-control" />
                </div>
                <span asp-validation-for="CategoriaPaiId" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="col-sm-3 mb-3">
        <label asp-for="Icone.IconeForm" class="form-label"></label>
        <div class="custom-file">
            <input asp-for="Icone.IconeForm" class="custom-file-input mb-2">
            <label class="custom-file-label" asp-for="Icone.IconeForm">Procurar ícone...</label>
            <img id="preview" class="img-fluid border-0 @(Model.Icone?.Conteudo == null ? "d-none" : string.Empty)"
                 src="data:@Model.Icone?.MimeType;base64,@Model.Icone?.Conteudo"
                 asp-append-version="true" height="78" width="78"/>
        </div>
        <span asp-validation-for="Icone.IconeForm" class="text-danger"></span>
    </div>
</div>

<hr />
<div class="mb-3">
    <input type="submit" value="Salvar" class="btn @(ViewBag.ClasseBotao)primary" />

    <a class="btn @(ViewBag.ClasseBotao)secondary" asp-action="Index">Cancelar</a>
</div>