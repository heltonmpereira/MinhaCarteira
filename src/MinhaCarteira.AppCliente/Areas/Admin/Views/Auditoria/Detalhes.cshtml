
@model MinhaCarteira.AppCliente.ViewModel.AuditoriaViewModel

@{
    ViewData["Title"] = "Auditoria";
    ViewData["Icone"] = "<i class='fa fa-history fa-lg d-inline'></i>";
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
}

<div class="col-11 px-sm-3 px-md-0 pt-4 mx-auto">
    <h1>Detalhes da Auditoria</h1>

    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DataHora)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.DataHora)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Acao)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Acao)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Entidade)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Entidade)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EntidadeId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.EntidadeId)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Usuario)</dt>
        <dd class="col-sm-9">@Model.Usuario?.NomeCompleto</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IpUsuario)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.IpUsuario)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.UserAgent)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.UserAgent)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Rotina)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Rotina)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DadosAntigos)</dt>
        <dd class="col-sm-9">
            <pre style="max-height:200px;overflow-y:auto;white-space:pre-wrap;word-wrap:break-word;background-color:#f5f5f5;padding:10px;border-radius:4px;">@Html.DisplayFor(model => model.DadosAntigos)</pre>
        </dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DadosNovos)</dt>
        <dd class="col-sm-9">
            <pre style="max-height:200px;overflow-y:auto;white-space:pre-wrap;word-wrap:break-word;background-color:#f5f5f5;padding:10px;border-radius:4px;">@Html.DisplayFor(model => model.DadosNovos)</pre>
        </dd>
    </dl>

    <hr />
    <a class="btn @(ViewBag.ClasseBotao)secondary" asp-action="Index">Voltar</a>
</div>
