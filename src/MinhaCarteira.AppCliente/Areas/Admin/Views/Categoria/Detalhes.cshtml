@model MinhaCarteira.AppCliente.ViewModel.CategoriaViewModel

@{
    ViewData["Title"] = "Categoria";
    ViewData["Icone"] = "<i class='fa fa-layer-group fa-lg d-inline'></i>";
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
}

<div class="col-11 px-sm-3 px-md-0 pt-4 mx-auto">
    <h1>Detalhes</h1>

    @Html.DisplayFor(model => model)

    <hr />
    <a class="btn @(ViewBag.ClasseBotao)secondary" asp-action="Index">Cancelar</a>
</div>
