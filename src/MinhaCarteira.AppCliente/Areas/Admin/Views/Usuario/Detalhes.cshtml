@{
    ViewData["Title"] = "Usuários";
    ViewData["Icone"] = "<i class='fa fa-user fa-lg'></i>";
    @section Scripts {
        <script src="~/lib/dompurify/purify.min.js" asp-append-version="true"></script>
        <script src="~/js/views/paginacao.js" asp-append-version="true"></script>
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
}

<div class="col-11 px-sm-3 px-md-0 pt-4 mx-auto">
    <h1>Detalhes</h1>

    @Html.DisplayFor(model => model)

    <div>
        <hr />
        <a class="btn @(ViewBag.ClasseBotao)secondary" asp-action="Index">Cancelar</a>
    </div>
</div>