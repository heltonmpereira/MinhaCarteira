@model MinhaCarteira.AppCliente.ViewModel.Login.AlterarSenhaViewModel

@{
    ViewData["Title"] = "Alterar Senha";
    @section Scripts {
        @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }
}

<form asp-action="AlterarSenha" method="post" class="col-sm-10 col-md-6 col-lg-4 px-5 pt-4">
    <h1>AlterarSenha</h1>
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="SenhaAtual" class="control-label"></label>
        <input asp-for="SenhaAtual" class="form-control" autofocus autocomplete="off" />
        <span asp-validation-for="SenhaAtual" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Novasenha" class="control-label"></label>
        <input asp-for="Novasenha" class="form-control" autocomplete="off" />
        <span asp-validation-for="Novasenha" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ConfirmarNovaSenha" class="control-label"></label>
        <input asp-for="ConfirmarNovaSenha" class="form-control" autocomplete="off" />
        <span asp-validation-for="ConfirmarNovaSenha" class="text-danger"></span>
    </div>

    <hr />
    <div class="form-group">
        <input asp-accessando-como type="submit" value="Salvar" class="btn btn-primary" />

        <a class="btn btn-default" asp-action="Index" asp-controller="Home">Cancelar</a>
    </div>
</form>