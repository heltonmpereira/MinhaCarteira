@using MinhaCarteira.AppCliente.ViewModel.Login;
@model RegistrarOrganizacaoViewModel

@{
    ViewData["Title"] = "Registrar";
    @section Scripts {
        @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }
}

<div class="col-md-11 pt-4 mx-auto">
    <h1>Registrar</h1>
    <form asp-action="Registrar" autocomplete="off">
        <fieldset class="form-group">
            <div class="row">
                <div class="form-group col-sm-12">
                    <label asp-for="Nome" class="control-label"></label>
                    <input asp-for="Nome" class="form-control" autofocus />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>
            </div>
        </fieldset>

        <hr/>
        <fieldset class="form-group">
            <legend class="col-form-label">Dados do administrador</legend>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="form-group col-sm-6">
                    <label asp-for="Administrador.Nome" class="control-label"></label>
                    <input asp-for="Administrador.Nome" class="form-control" autofocus />
                    <span asp-validation-for="Administrador.Nome" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="Administrador.Sobrenome" class="control-label"></label>
                    <input asp-for="Administrador.Sobrenome" class="form-control" />
                    <span asp-validation-for="Administrador.Sobrenome" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="form-group col-sm-6">
                    <label asp-for="Administrador.Username" class="control-label"></label>
                    <input asp-for="Administrador.Username" class="form-control" autocomplete="off" />
                    <span asp-validation-for="Administrador.Username" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="Administrador.Email" class="control-label"></label>
                    <input asp-for="Administrador.Email" class="form-control" />
                    <span asp-validation-for="Administrador.Email" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="form-group col-sm-6">
                    <label asp-for="Administrador.Password" class="control-label"></label>
                    <input asp-for="Administrador.Password" class="form-control" autocomplete="off" />
                    <span asp-validation-for="Administrador.Password" class="text-danger"></span>
                </div>
                <div class="form-group col-sm-6">
                    <label asp-for="Administrador.ConfirmarPassword" class="control-label"></label>
                    <input asp-for="Administrador.ConfirmarPassword" class="form-control" />
                    <span asp-validation-for="Administrador.ConfirmarPassword" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <hr />
                <input type="submit" value="Registrar" class="btn @(ViewBag.ClasseBotao)primary" />

                <a class="btn @(ViewBag.ClasseBotao)secondary" asp-action="Index">Cancelar</a>
            </div>
        </fieldset>
    </form>
</div>