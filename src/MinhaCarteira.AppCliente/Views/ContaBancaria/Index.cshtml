@using MinhaCarteira.AppCliente.Models.Interface;
@using MinhaCarteira.AppCliente.ViewModel.Base;
@using MinhaCarteira.AppCliente.ViewModel;
@model ListaBaseViewModel<ContaBancariaViewModel>

@{
    ViewData["Title"] = "Conta Bancária";
    ViewData["Icone"] = "<i class='fa fa-money-check-dollar fa-lg d-inline'></i>";
    ViewData["LinkNovo"] = Url.Action("Incluir");

    var classBotao = ViewBag.Theme == "dark" ? string.Empty : "-outline";
    var filtro = Model == null ? null : Model.FiltroViewModel;
    await Html.RenderPartialAsync("_PartialFiltro", filtro);
}

@section ItensCabecalho
{
    <li class="nav-item pl-3">
        <a class='nav-link bg-info text-nowrap' role="button" asp-action="AtualizarSaldos" title="Atualizar saldos das contas bancárias">
            <i class='d-inline fa fa-rotate'></i>
            <span class="d-inline">Saldos</span>
        </a>
    </li>
}

@section Scripts {
    <script src="~/lib/dompurify/purify.min.js" asp-append-version="true"></script>
    <script src="~/js/views/paginacao.js" asp-append-version="true"></script>
}


@if ((ViewBag?.RetornoApi == null || ViewBag?.RetornoApi.BemSucedido) && (Model == null || !Model.Itens.Any()))
{
    <asp-alerta-vazio class="col-11 mx-auto mt-4 p-4 rounded-3 border shadow-sm" criterio="filtro" titulo="Conta Bancária" icone-botao-cadastrar="fa-money-check-dollar" />
}
else
{
    var tableTheme = $"table-{ViewBag.Theme}";

    <div class="table-responsive col-sm-11 px-sm-3 px-md-0 pt-4 mx-auto">
        <table class="table table-striped table-hover table-valign-middle @tableTheme">
            <thead class="table-primary">
                <tr>
                    @* <th width="48"></th> *@
                    <th>
                        <asp-cabecalho asp-for="Itens.FirstOrDefault().Nome" />
                    </th>
                    <th>
                        <asp-cabecalho asp-for="Itens.FirstOrDefault().Agencia" />
                    </th>
                    <th>
                        <asp-cabecalho asp-for="Itens.FirstOrDefault().Conta" />
                    </th>
                    <th>
                        <asp-cabecalho asp-for="Itens.FirstOrDefault().ValorSaldoAtual" />
                    </th>
                    <th colspan="3">Ações</th>
                </tr>
            </thead>
            <tbody class="table-group-divider">
                @foreach (var item in Model.Itens)
                {
                    var classDesabilitado = item.Deletado ? "table-secondary fst-italic table-danger" : "";
                    var classBotaoSubir = item.Ordem == 1 ? "disabled" : "";
                    var classBotaoDescer = item.Ordem == Model.Itens.Count ? "disabled" : "";

                    <tr class="align-middle @classDesabilitado">
                        <td>
                            <div>
                                @if (!string.IsNullOrWhiteSpace(item.InstituicaoFinanceira.Icone?.Conteudo))
                                {
                                    <img src="data:@item.InstituicaoFinanceira.Icone.MimeType;base64,@item.InstituicaoFinanceira.Icone.Conteudo"
                                         height="36" width="36" class="me-2"
                                         alt="@item.InstituicaoFinanceira.Nome"
                                         asp-append-version="true" />
                                }

                                @Html.DisplayFor(modelItem => item.Nome)
                            </div>
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Agencia)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Conta)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ValorSaldoAtual)
                        </td>

                        <td class="p-2 align-content-center w150px">
                            <div class="btn-group" role="group" aria-label="Botões de ação">
                                <a title="Ordenar" class="btn btn@(classBotao)-secondary btn-acao p-0 pt-1 pb-1 @classBotaoSubir" asp-action="IncrementarPrioridade" asp-route-id="@item.Id">
                                    <i class="fa-solid fa-lg fa-arrow-up"></i>
                                </a>
                                <a title="Ordenar" class="btn btn@(classBotao)-secondary btn-acao p-0 pt-1 pb-1 @classBotaoDescer" asp-action="DecrementarPrioridade" asp-route-id="@item.Id">
                                    <i class="fa-solid fa-lg fa-arrow-down"></i>
                                </a>

                                <a title="Alterar" class="btn btn@(classBotao)-primary btn-acao p-0 pt-1 pb-1" asp-action="Alterar" asp-route-id="@item.Id">
                                    <i class="fa-solid fa-lg fa-pen-to-square"></i>
                                </a>

                                <a title="Detalhes" class="btn btn@(classBotao)-success btn-acao p-0 pt-1 pb-1" asp-action="Detalhes" asp-route-id="@item.Id">
                                    <i class="fa-solid fa-lg fa-info-circle"></i>
                                </a>

                                @if (!item.Deletado)
                                {
                                    <a title="Remover" class="btn btn@(classBotao)-danger btn-acao p-0 pt-1 pb-1" asp-action="Deletar" asp-route-id="@item.Id">
                                        <i class="fa-solid fa-lg fa-trash-can"></i>
                                    </a>
                                }
                                else
                                {
                                    <a title="Reativar" class="btn btn@(classBotao)-primary btn-acao p-0 pt-1 pb-1" asp-action="Reativar" asp-route-id="@item.Id">
                                        <i class="fa-solid fa-lg fa-recycle"></i>
                                    </a>
                                }

                                <a title="Clonar" class="btn btn@(classBotao)-info btn-acao p-0 pt-1 pb-1" asp-action="Clonar" asp-route-id="@item.Id">
                                    <i class="fa-solid fa-lg fa-clone"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    await Html.RenderPartialAsync("_PartialPaginacao", Model.Itens);
}
